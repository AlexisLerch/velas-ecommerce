generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  price       Int
  description String?
  image       String
  slug        String   @unique
  stock       Int
  createdAt   DateTime @default(now())
}

model CartItem {
  id        String  @id @default(cuid())
  userId    String
  productId String
  name      String
  price     Float
  quantity  Int
}